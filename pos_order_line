-- Table: public.pos_order_line

-- DROP TABLE public.pos_order_line;

CREATE TABLE public.pos_order_line
(
    id integer NOT NULL DEFAULT nextval('pos_order_line_id_seq'::regclass),
    company_id integer,
    product_id integer NOT NULL,
    order_id integer NOT NULL,
    refunded_orderline_id integer,
    combo_parent_id integer,
    combo_item_id integer,
    create_uid integer,
    write_uid integer,
    name character varying COLLATE pg_catalog."default" NOT NULL,
    notice character varying COLLATE pg_catalog."default",
    price_type character varying COLLATE pg_catalog."default",
    full_product_name character varying COLLATE pg_catalog."default",
    customer_note character varying COLLATE pg_catalog."default",
    uuid character varying COLLATE pg_catalog."default",
    note character varying COLLATE pg_catalog."default",
    extra_tax_data jsonb,
    price_unit numeric,
    qty numeric,
    price_subtotal numeric NOT NULL,
    price_subtotal_incl numeric NOT NULL,
    total_cost numeric,
    discount numeric,
    is_total_cost_computed boolean,
    is_edited boolean,
    create_date timestamp without time zone,
    write_date timestamp without time zone,
    price_extra double precision,
    course_id integer,
    combo_id integer,
    CONSTRAINT pos_order_line_pkey PRIMARY KEY (id),
    CONSTRAINT pos_order_line_unique_uuid UNIQUE (uuid),
    CONSTRAINT pos_order_line_combo_id_fkey FOREIGN KEY (combo_id)
        REFERENCES public.product_combo (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_combo_item_id_fkey FOREIGN KEY (combo_item_id)
        REFERENCES public.product_combo_item (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_combo_parent_id_fkey FOREIGN KEY (combo_parent_id)
        REFERENCES public.pos_order_line (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_company_id_fkey FOREIGN KEY (company_id)
        REFERENCES public.res_company (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_course_id_fkey FOREIGN KEY (course_id)
        REFERENCES public.restaurant_order_course (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_create_uid_fkey FOREIGN KEY (create_uid)
        REFERENCES public.res_users (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_order_id_fkey FOREIGN KEY (order_id)
        REFERENCES public.pos_order (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE CASCADE,
    CONSTRAINT pos_order_line_product_id_fkey FOREIGN KEY (product_id)
        REFERENCES public.product_product (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE RESTRICT,
    CONSTRAINT pos_order_line_refunded_orderline_id_fkey FOREIGN KEY (refunded_orderline_id)
        REFERENCES public.pos_order_line (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_line_write_uid_fkey FOREIGN KEY (write_uid)
        REFERENCES public.res_users (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL
)

TABLESPACE pg_default;

