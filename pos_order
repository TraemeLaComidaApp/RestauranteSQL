-- Table: public.pos_order

-- DROP TABLE public.pos_order;

CREATE TABLE public.pos_order
(
    id integer NOT NULL DEFAULT nextval('pos_order_id_seq'::regclass),
    user_id integer,
    company_id integer NOT NULL,
    pricelist_id integer,
    partner_id integer,
    sequence_number integer,
    session_id integer,
    config_id integer,
    account_move integer,
    preset_id integer,
    nb_print integer,
    sale_journal integer,
    fiscal_position_id integer,
    create_uid integer,
    write_uid integer,
    access_token character varying COLLATE pg_catalog."default",
    name character varying COLLATE pg_catalog."default" NOT NULL,
    last_order_preparation_change character varying COLLATE pg_catalog."default",
    state character varying COLLATE pg_catalog."default",
    floating_order_name character varying COLLATE pg_catalog."default",
    pos_reference character varying COLLATE pg_catalog."default",
    ticket_code character varying COLLATE pg_catalog."default",
    tracking_number character varying COLLATE pg_catalog."default",
    uuid character varying COLLATE pg_catalog."default",
    email character varying COLLATE pg_catalog."default",
    mobile character varying COLLATE pg_catalog."default",
    source character varying COLLATE pg_catalog."default",
    shipping_date date,
    general_customer_note text COLLATE pg_catalog."default",
    internal_note text COLLATE pg_catalog."default",
    amount_difference numeric,
    amount_tax numeric NOT NULL,
    amount_total numeric NOT NULL,
    amount_paid numeric NOT NULL,
    amount_return numeric NOT NULL,
    currency_rate numeric,
    tip_amount numeric,
    is_refund boolean,
    to_invoice boolean,
    is_tipped boolean,
    has_deleted_line boolean,
    date_order timestamp without time zone,
    preset_time timestamp without time zone,
    create_date timestamp without time zone,
    write_date timestamp without time zone,
    next_online_payment_amount numeric,
    table_id integer,
    customer_count integer,
    self_ordering_table_id integer,
    table_stand_number character varying COLLATE pg_catalog."default",
    use_self_order_online_payment boolean,
    CONSTRAINT pos_order_pkey PRIMARY KEY (id),
    CONSTRAINT pos_order_unique_uuid UNIQUE (uuid),
    CONSTRAINT pos_order_account_move_fkey FOREIGN KEY (account_move)
        REFERENCES public.account_move (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_company_id_fkey FOREIGN KEY (company_id)
        REFERENCES public.res_company (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE RESTRICT,
    CONSTRAINT pos_order_config_id_fkey FOREIGN KEY (config_id)
        REFERENCES public.pos_config (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_create_uid_fkey FOREIGN KEY (create_uid)
        REFERENCES public.res_users (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_fiscal_position_id_fkey FOREIGN KEY (fiscal_position_id)
        REFERENCES public.account_fiscal_position (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_partner_id_fkey FOREIGN KEY (partner_id)
        REFERENCES public.res_partner (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_preset_id_fkey FOREIGN KEY (preset_id)
        REFERENCES public.pos_preset (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_pricelist_id_fkey FOREIGN KEY (pricelist_id)
        REFERENCES public.product_pricelist (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_sale_journal_fkey FOREIGN KEY (sale_journal)
        REFERENCES public.account_journal (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE RESTRICT,
    CONSTRAINT pos_order_self_ordering_table_id_fkey FOREIGN KEY (self_ordering_table_id)
        REFERENCES public.restaurant_table (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_session_id_fkey FOREIGN KEY (session_id)
        REFERENCES public.pos_session (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_table_id_fkey FOREIGN KEY (table_id)
        REFERENCES public.restaurant_table (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_user_id_fkey FOREIGN KEY (user_id)
        REFERENCES public.res_users (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL,
    CONSTRAINT pos_order_write_uid_fkey FOREIGN KEY (write_uid)
        REFERENCES public.res_users (id) MATCH SIMPLE
        ON UPDATE NO ACTION
        ON DELETE SET NULL
)

TABLESPACE pg_default;

